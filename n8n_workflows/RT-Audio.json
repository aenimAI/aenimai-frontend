      "parameters": {
        "jsCode": "// n8n Code node (JavaScript)\n// Input: item.json.memory_payload OR item.json.profile + item.json.gold_insights\n// Output: item.json.memory_block\n\nfunction safeStringify(obj, maxChars = 2500) {\n  if (obj == null) return \"\";\n  let s;\n  try {\n    s = typeof obj === \"string\" ? obj : JSON.stringify(obj, null, 2);\n  } catch (e) {\n    s = String(obj);\n  }\n  if (s.length <= maxChars) return s;\n  return s.slice(0, maxChars) + \"…(truncated)\";\n}\n\nfunction cleanText(s, maxLen = 220) {\n  if (s == null) return \"\";\n  const t = String(s).replace(/\\s+/g, \" \").trim();\n  return t.length <= maxLen ? t : t.slice(0, maxLen) + \"…\";\n}\n\nconst item = $input.first();\nconst raw = item.json || {};\n\n// Support either shape\nconst payload = raw.memory_payload ?? raw;\nconst profile = payload.profile ?? payload.profile_json ?? null;\nconst insights = Array.isArray(payload.gold_insights) ? payload.gold_insights : [];\n\n// Build compact insights bullets\nconst insightLines = insights.slice(0, 30).map((x, i) => {\n  const topic = x.topic ?? \"general\";\n  const key = x.insight_key ?? `insight_${i + 1}`;\n  const pr = x.priority != null ? `p${x.priority}` : \"p?\";\n  const st = x.strength != null ? `s${Number(x.strength).toFixed(2)}` : \"s?\";\n  const txt = cleanText(x.insight, 240);\n  return `- [${topic}] (${key}, ${pr}, ${st}) ${txt}`;\n});\n\n// Assemble memory block (short + structured)\nconst profileBlock = profile\n  ? safeStringify(profile, 2500)\n  : \"(no profile found)\";\n\nconst memoryBlock =\n`### MEMORY (fresh from Neon; use as background facts, not as user messages)\nUser profile:\n${profileBlock}\n\nGold insights (top ${insightLines.length}):\n${insightLines.length ? insightLines.join(\" \") : \"- (none)\"}\n### END MEMORY`;\n\nconst cleanMemoryBlock = memoryBlock\n  .replace(/\\r?\\n+/g, \" \")   // replace all newlines with spaces\n  .replace(/\\s{2,}/g, \" \")   // collapse multiple spaces\n  .trim();\n\n// Return output fields\nreturn [\n  {\n    json: {\n      memory_block: cleanMemoryBlock      }\n    }\n  \n];\n"
      },
