        "jsCode": "const history = $items(\"Get Session\").map(i => i.json);\n\nlet cleanString = history\n  .map(m => `${m.role}: ${m.text}`)\n  .join(\" \");\n\n// Remove ALL newline characters (hard line breaks)\ncleanString = cleanString.replace(/\\n/g, \" \");\n\nreturn [\n  {\n    json: {\n      session_string: cleanString\n    }\n  }\n];\n\n\n\n"
