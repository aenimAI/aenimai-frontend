        "query": "WITH p AS (\n  SELECT profile_json\n  FROM public.user_profile\n  WHERE user_id = 'default_user'\n  LIMIT 1\n),\ng AS (\n  SELECT jsonb_agg(\n           jsonb_build_object(\n             'topic', topic,\n             'insight_key', insight_key,\n             'insight', insight,\n             'strength', strength,\n             'priority', priority\n           )\n           ORDER BY priority DESC, strength DESC\n         ) AS insights\n  FROM (\n    SELECT topic, insight_key, insight, strength, priority\n    FROM public.gold_insights\n    ORDER BY priority DESC, strength DESC\n    LIMIT 30\n  ) t\n)\nSELECT jsonb_build_object(\n  'profile', (SELECT profile_json FROM p),\n  'gold_insights', COALESCE((SELECT insights FROM g), '[]'::jsonb)\n) AS memory_payload;\n\n",
